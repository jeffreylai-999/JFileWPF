<Window x:Class="com.jl.jfilewpf.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Icon="/Assets/main.png"
        AllowsTransparency="True"
        Background="Transparent"
        Title="JFileWPF"
        Height="550"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        FontFamily="Segoe UI Emoji">
    <Window.Resources>
        <Style x:Key="CheckBoxRow" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF0FB" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="White"
          Margin="10"
          MouseDown="Grid_MouseDown">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="12"
                              Direction="-90"
                              RenderingBias="Quality"
                              ShadowDepth="2"
                              Color="#FFBBBBBB" />
        </Grid.Effect>
        <Rectangle Height="280"
                   VerticalAlignment="Top">
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1"
                                     StartPoint="0.5,0.05">
                    <GradientStop Color="#FF2281D1" />
                    <GradientStop Color="#FF34268A"
                                  Offset="1" />
                    <GradientStop Color="#FF33288B"
                                  Offset="0.555" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle Width="300"
                   Height="300"
                   VerticalAlignment="Bottom"
                   Margin="0,80"
                   RadiusY="10"
                   RadiusX="10"
                   Fill="White">
            <Rectangle.Effect>
                <DropShadowEffect BlurRadius="15"
                                  Direction="0"
                                  RenderingBias="Quality"
                                  ShadowDepth="1"
                                  Color="#FFBBBBBB" />
            </Rectangle.Effect>
        </Rectangle>

        <Image Source="/Assets/main.png"
               Width="100"
               Height="100"
               VerticalAlignment="Top"
               Margin="30" />

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right">
            <Button Style="{StaticResource TitleBarButton}" Click="Settings_Click">
                <materialDesign:PackIcon Kind="Settings" />
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Keywords List" Click="KeywordList_Click" />
                        <MenuItem Header="Configuration" Click="Setup_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Button Style="{StaticResource TitleBarButton}" Click="Close_Click">
                <materialDesign:PackIcon Kind="Close" />
            </Button>
        </StackPanel>

        <Grid VerticalAlignment="Bottom"
              Margin="40,80"
              Height="300">
            <Grid.RowDefinitions>
                <RowDefinition Height="45" />
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
            </Grid.RowDefinitions>

            <Label Grid.Row="0"
                   Content="JFILE WPF"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="Gray"
                   FontSize="24" />

            <Button Grid.Row="1"
                    Width="180"
                    Height="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="SELECT"
                    Click="Select_Click"
                    FontSize="16"
                    Background="#5c6bc0"
                    BorderBrush="{x:Null}"
                    materialDesign:ButtonAssist.CornerRadius="25"
                    materialDesign:ElevationAssist.Elevation="Dp3" />

            <StackPanel Grid.Row="3"
                        Margin="10,0">
                <Border Style="{StaticResource CheckBoxRow}">
                    <CheckBox Background="#7986cb"
                              Foreground="#37474F"
                              FontFamily="Champagne &amp; Limousines"
                              FontSize="16"
                              x:Name="Cb_Trim"
                              Content="Trim text" />
                </Border>
                <Border Style="{StaticResource CheckBoxRow}">
                    <CheckBox Background="#7986cb"
                              Foreground="#37474F"
                              FontFamily="Champagne &amp; Limousines"
                              FontSize="16"
                              x:Name="Cb_Tab2Spaces"
                              Content="Convert TAB to 3 spaces" />
                </Border>
                <Border Style="{StaticResource CheckBoxRow}">
                    <CheckBox Background="#7986cb"
                              Foreground="#37474F"
                              FontFamily="Champagne &amp; Limousines"
                              FontSize="16"
                              x:Name="Cb_Keyword2Upper"
                              Content="Convert keywords to UPPERCASE" />
                </Border>
                <Border Style="{StaticResource CheckBoxRow}">
                    <CheckBox Background="#7986cb"
                              Foreground="#37474F"
                              FontFamily="Champagne &amp; Limousines"
                              FontSize="16"
                              x:Name="Cb_Override"
                              Content="Do not override original file" />
                </Border>
            </StackPanel>

        </Grid>
    </Grid>
</Window>

