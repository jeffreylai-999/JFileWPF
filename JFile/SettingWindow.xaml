<Window x:Class="JFile.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ResizeMode="NoResize" 
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"
        FontFamily="Segoe UI Emoji"
        Height="400" Width="400">
    <Border BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" BlurRadius="10" ShadowDepth="3" />
        </Border.Effect>
        <Grid Background="White">
            <Grid Background="#3f51b5" MouseDown="Grid_MouseDown" Height="41" VerticalAlignment="Top">
                <Label Content="Setting" Foreground="White" FontSize="16" Margin="10,5"></Label>
                <Button HorizontalAlignment="Right" Margin="0,5" Grid.Column="1" Click="Close_Click" Background="{x:Null}" BorderBrush="{x:Null}">
                    <materialDesign:PackIcon Kind="Close" />
                </Button>
            </Grid>

            <StackPanel Margin="30,70,30,100">
                <CheckBox Background="#7986cb" x:Name="Cb_Trim" Margin="0,5" Content="Default Trim Text" Foreground="Gray" FontFamily="Champagne &amp; Limousines" FontSize="18"/>
                <CheckBox Background="#7986cb" x:Name="Cb_Tab2Spaces" Margin="0,5" Content="Default Convert Tab To Space" Foreground="Gray" FontFamily="Champagne &amp; Limousines" FontSize="18"/>
                <CheckBox Background="#7986cb" x:Name="Cb_Keyword2Upper" Margin="0,5" Content="Default Convert Keyword To Uppercase" Foreground="Gray" FontFamily="Champagne &amp; Limousines" FontSize="18"/>
                <CheckBox Background="#7986cb" x:Name="Cb_Override" Margin="0,5" Content="Default Override the File" Foreground="Gray" FontFamily="Champagne &amp; Limousines" FontSize="18"/>
                <TextBox x:Name="Tb_Space" Margin="0,5" materialDesign:HintAssist.Hint="Default Tab Space" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontFamily="Champagne &amp; Limousines" FontSize="18" PreviewTextInput="NumberValidationTextBox"/>
            </StackPanel>

            <Button VerticalAlignment="Bottom" Margin="30,30" Height="50" Content="Save" FontSize="18" Click="Save_Click" Background="#5c6bc0" BorderBrush="{x:Null}" materialDesign:ButtonAssist.CornerRadius="25" materialDesign:ShadowAssist.ShadowDepth="Depth2"></Button>
        </Grid>

    </Border>
</Window>
